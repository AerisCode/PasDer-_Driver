<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_spinner_kuning"
    android:padding="12dp"
    android:layout_marginBottom="12dp">

    <FrameLayout
        android:id="@+id/img_frame_item"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_foto_notif"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_title_item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Nama Paket"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/img_frame_item"
        app:layout_constraintTop_toTopOf="@id/img_frame_item" />

    <TextView
        android:id="@+id/tv_detail_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Detail Penyewa"
        android:textSize="11sp"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="@id/tv_title_item"
        app:layout_constraintTop_toBottomOf="@id/tv_title_item" />
</androidx.constraintlayout.widget.ConstraintLayout>